# Example secrets for the `local` profile.
#
# Copy this file to `local-launch/local-secrets.env` and adjust values if you point
# at non-default local infrastructure. The real `*-secrets.env` file is
# gitignored — only this `.example` template is committed.
#
# `local-launch/launch-all.sh start local` sources the matching secrets file and
# exports each line as an environment variable; the conv-agent reads them
# directly via `readConvAgentCredentials(process.env)`.

# LocalStack S3 defaults.
BLOB_STORAGE_ACCESS_KEY_ID=test
BLOB_STORAGE_SECRET_ACCESS_KEY=test

# LocalStack SQS defaults.
LLM_DISPATCH_QUEUE_ACCESS_KEY_ID=test
LLM_DISPATCH_QUEUE_SECRET_ACCESS_KEY=test

# Local Postgres defaults (see local-launch/launch-deps-local.sh).
DATABASE_USERNAME=thoth
DATABASE_PASSWORD=thoth
