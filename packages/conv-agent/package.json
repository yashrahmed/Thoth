{
  "name": "@thoth/conv-agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun x tsc --noEmit",
    "test": "bun test --pass-with-no-tests src/adapter src/application src/config src/domain src/worker",
    "test:integration": "bun test --timeout 180000 src/integration",
    "typecheck": "bun x tsc --noEmit",
    "worker:dev": "wrangler dev --config ../../local-launch/wrangler-local.toml",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "hono": "^4.12.9",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "wrangler": "^4.0.0"
  }
}
