# Example secrets for the `local` profile.
#
# Copy this file to `~/.thoth/local-secrets.env` and adjust values if you point
# at non-default local infrastructure. The real `*-secrets.env` file is
# kept outside the repo; only this `.example` template is committed.
#
# `local-launch/launch-all.sh start local` copies the matching secrets file to
# `local-launch/.dev.vars`; Wrangler loads it when the worker boots.

# Local migration connection used by the launch script's Flyway step.
MIGRATION_DATABASE_URL=postgresql://thoth:thoth@127.0.0.1:5432/thoth
