{
  "name": "thoth",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:local:setup": "./scripts/db-local.sh start",
    "db:local:down": "./scripts/db-local.sh stop",
    "db:local:start": "./scripts/db-local.sh start",
    "db:local:stop": "./scripts/db-local.sh stop",
    "db:local:up": "docker compose --env-file db/local/.env -f db/local/docker-compose.yml up -d postgres",
    "db:local:migrate": "docker compose --env-file db/local/.env -f db/local/docker-compose.yml up -d postgres && docker compose --env-file db/local/.env -f db/local/docker-compose.yml --profile migrations run --rm flyway migrate",
    "dev:local:start": "./scripts/launch-all-servers-local.sh start",
    "dev:local:restart": "./scripts/launch-all-servers-local.sh restart",
    "dev:local:stop": "./scripts/launch-all-servers-local.sh stop",
    "dev:proxy": "bun run --filter @thoth/message-proxy dev",
    "dev:web": "bun run --filter @thoth/web dev",
    "graph:conv-agent": "bun scripts/generate-conv-call-graph.ts",
    "llm:prompt": "bun scripts/prompt-llm.ts",
    "r2:upload": "bun scripts/r2-ops.ts upload",
    "r2:download": "bun scripts/r2-ops.ts download",
    "format": "bun x prettier . --write",
    "format:check": "bun x prettier . --check",
    "lint": "bun x eslint .",
    "lint:fix": "bun x eslint . --fix",
    "lint:dead": "bun x knip",
    "lint:deps": "bun x depcruise --config .dependency-cruiser.cjs packages",
    "build": "bun x tsc --noEmit -p tsconfig.domain.json && bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:integration:conv-agent": "bun run --filter @thoth/conv-agent test:integration",
    "typecheck": "bun x tsc --noEmit -p tsconfig.domain.json && bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "knip": "^5.86.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {}
}
