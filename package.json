{
  "name": "thoth",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/domain/*"
  ],
  "scripts": {
    "db:local:setup": "./scripts/db-local-launch.sh",
    "db:local:down": "./scripts/db-local-stop.sh",
    "db:local:up": "docker compose -f db/local/docker-compose.yml up -d postgres",
    "db:local:migrate": "docker compose -f db/local/docker-compose.yml up -d postgres && docker compose -f db/local/docker-compose.yml --profile migrations run --rm flyway migrate",
    "dev:agents": "bun run --filter @thoth/agents start",
    "dev:proxy": "bun run --filter @thoth/message-proxy dev",
    "dev:web": "bun run --filter @thoth/web dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "dependencies": {
    "ai": "^6.0.116"
  }
}
