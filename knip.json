{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "bun": false,
  "workspaces": {
    ".": {
      "entry": ["local-launch/**/*.ts"],
      "project": ["local-launch/**/*.ts"]
    },
    "packages/conv-agent": {
      "entry": ["src/setup.test.ts", "src/integration/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/domain/contracts": {
      "project": ["**/*.ts"]
    },
    "packages/domain/entities": {
      "project": ["**/*.ts"]
    },
    "packages/message-proxy": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/mobile": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/web": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
