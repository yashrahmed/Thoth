{
  "name": "thoth",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/domain/*"
  ],
  "scripts": {
    "dev:agents": "bun run --filter @thoth/agents start",
    "dev:proxy": "bun run --filter @thoth/message-proxy dev",
    "dev:web": "bun run --filter @thoth/web dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "dependencies": {
    "ai": "^6.0.116"
  }
}
