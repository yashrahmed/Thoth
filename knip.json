{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/conv-agent": {
      "entry": ["src/**/*server.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/kb-curate-agent": {
      "entry": ["src/**/*server.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/planning-agent": {
      "entry": ["src/**/*server.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/config": {
      "project": ["src/**/*.ts"]
    },
    "packages/domain/contracts": {
      "project": ["**/*.ts"]
    },
    "packages/domain/entities": {
      "project": ["**/*.ts"]
    },
    "packages/message-proxy": {
      "project": ["src/**/*.ts"]
    },
    "packages/mobile": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/web": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
